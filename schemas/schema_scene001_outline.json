{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "课程大纲输出Schema",
    "type": "object",
    "required": ["course_name", "total_periods", "chapters"],
    "properties": {
        "course_name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100
        },
        "course_desc": {
            "type": "string",
            "maxLength": 500
        },
        "total_periods": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100
        },
        "chapters": {
            "type": "array",
            "minItems": 1,
            "maxItems": 20,
            "items": {
                "type": "object",
                "required": ["chapter_name", "periods", "objectives"],
                "properties": {
                    "chapter_name": {
                        "type": "string",
                        "minLength": 1,
                        "maxLength": 100
                    },
                    "periods": {
                        "type": "integer",
                        "minimum": 1,
                        "maximum": 30
                    },
                    "objectives": {
                        "type": "array",
                        "minItems": 1,
                        "items": {
                            "type": "string"
                        }
                    },
                    "teaching_method": {
                        "type": "string",
                        "enum": ["讲授法", "探究法", "项目式", "讨论法", "案例教学", "混合教学"]
                    }
                }
            }
        },
        "assessment_methods": {
            "type": "array",
            "items": {
                "type": "string"
            }
        }
    }
}
